root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.{md,markdown}]
trim_trailing_whitespace = false

[*.{ps1,bat,cmd}]
end_of_line = crlf

[Makefile]
indent_style = tab

[*.{xlsx,xls,pdf,ttf,otf,png,jpg,jpeg,gif,ico,woff,woff2}]
charset = unset
end_of_line = unset
insert_final_newline = unset
trim_trailing_whitespace = unset
