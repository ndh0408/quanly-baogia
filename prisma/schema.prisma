generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  manager
  account_hn // Account Hà Nội: CHỈ điền bảng nội bộ loại "hanoi" của báo giá được giao, không thấy gì khác
}

enum QuoteStatus {
  draft
  pending
  approved
  rejected
  sent
  converted
  lost
}

enum CustomerStatus {
  lead
  prospect
  active
  inactive
}

enum ApprovalDecision {
  pending
  approved
  rejected
}

enum NotificationChannel {
  in_app
  email
  telegram
}

model User {
  id           Int     @id @default(autoincrement())
  username     String  @unique
  passwordHash String
  displayName  String
  email        String? @unique
  role         Role    @default(manager)
  phone        String?
  title        String?
  senderName   String? // tên hiển thị làm "Người gửi" trên báo giá (nếu khác Họ tên đăng nhập)
  projectCode  String? // prefix mã dự án của nhân viên (vd FE_A26) — báo giá họ tạo đánh FE_A26_001…
  active       Boolean @default(true)
  canSign      Boolean @default(false) // được "Ký Chứng từ" dự án DO MÌNH TẠO ở trang Quản lý dự án (admin ký + thấy toàn bộ)

  // Email-invite onboarding: invited users are inactive until they accept,
  // set their own password and fill in their details.
  inviteTokenHash String?
  inviteExpiresAt DateTime?

  failedAttempts Int       @default(0)
  lockedUntil    DateTime?
  lastLoginAt    DateTime?
  lastLoginIp    String?

  // MFA TOTP
  mfaEnabled     Boolean  @default(false)
  mfaSecret      String?
  mfaBackupCodes String[] @default([])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  createdQuotes     Quote[]        @relation("CreatedBy")
  approvedQuotes    Quote[]        @relation("ApprovedBy")
  memberQuotes      Quote[]        @relation("QuoteMembers") // báo giá được thêm vào làm thành viên
  ownedCustomers    Customer[]
  auditEvents       AuditEvent[]
  notifications     Notification[]
  approvals         Approval[]
  refreshTokens     RefreshToken[]
  // Back-relations for previously-bare Int references (now real FKs, onDelete: SetNull).
  authoredNotes     CustomerNote[] @relation("NoteAuthor")
  assignedFollowUps FollowUp[]     @relation("FollowupAssignee")
  authoredVersions  QuoteVersion[] @relation("VersionAuthor")
  signedSheets      QuoteSheet[]   @relation("SheetSigner")

  @@index([deletedAt, active])
}

model RefreshToken {
  id        BigInt    @id @default(autoincrement())
  userId    Int
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  family    String // rotation family id; revoke whole family on reuse
  ip        String?
  userAgent String?
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, expiresAt])
  @@index([family])
}

model Company {
  id          Int             @id @default(autoincrement())
  code        String          @unique
  name        String
  shortName   String?
  quotePrefix String          @default("GN") // số báo giá riêng theo công ty (VD: GN, CLF)
  address     String
  city        String          @default("TP. Hồ Chí Minh")
  phone       String?
  email       String?
  taxCode     String?
  logoPath    String?
  active      Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  deletedAt   DateTime?
  templates   QuoteTemplate[]
  quotes      Quote[]

  @@index([deletedAt, active])
}

model QuoteTemplate {
  id        Int          @id @default(autoincrement())
  code      String       @unique
  name      String
  companyId Int
  company   Company      @relation(fields: [companyId], references: [id])
  filePath  String
  active    Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  deletedAt DateTime?
  sheets    QuoteSheet[]

  @@index([companyId, active])
}

// === CRM ===
model Customer {
  id           Int            @id @default(autoincrement())
  code         String         @unique
  name         String
  taxCode      String?
  email        String?
  phone        String?
  address      String?
  city         String?
  contactName  String?
  contactTitle String?
  status       CustomerStatus @default(lead)
  tags         String[]       @default([])
  ownerId      Int?
  owner        User?          @relation(fields: [ownerId], references: [id])
  notes        CustomerNote[]
  followUps    FollowUp[]
  quotes       Quote[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  deletedAt    DateTime?

  @@index([deletedAt, status])
  @@index([ownerId])
  @@index([name])
}

model CustomerNote {
  id         Int      @id @default(autoincrement())
  customerId Int
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  body       String
  authorId   Int?
  author     User?    @relation("NoteAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())

  @@index([customerId, createdAt(sort: Desc)])
  @@index([authorId])
}

model FollowUp {
  id         Int       @id @default(autoincrement())
  customerId Int
  customer   Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  dueAt      DateTime
  doneAt     DateTime?
  note       String
  assigneeId Int?
  assignee   User?     @relation("FollowupAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  createdAt  DateTime  @default(now())

  @@index([customerId, dueAt])
  @@index([assigneeId, doneAt, dueAt])
}

// === Product Catalog ===
model Product {
  id          Int                @id @default(autoincrement())
  sku         String             @unique
  name        String
  category    String?
  unit        String?
  costPrice   Decimal            @default(0) @db.Decimal(18, 4)
  basePrice   Decimal            @default(0) @db.Decimal(18, 4)
  description String?
  active      Boolean            @default(true)
  priceTiers  ProductPriceTier[]
  quoteItems  QuoteItem[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  deletedAt   DateTime?

  @@index([deletedAt, active])
  @@index([category])
  @@index([name])
}

model ProductPriceTier {
  id        Int     @id @default(autoincrement())
  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  name      String // "Sỉ", "Lẻ", "VIP"
  minQty    Int     @default(0)
  price     Decimal @db.Decimal(18, 4)

  @@unique([productId, name])
}

// === Quote ===
model Quote {
  id             Int         @id @default(autoincrement())
  quoteNumber    String      @unique
  projectCode    String? // mã dự án theo nhân viên (FE_A26_001…); hiển thị trong app, KHÔNG vào Excel
  projectVersion Int         @default(1) // bản gửi khách v1/v2/v3 (cùng projectCode, mỗi bản 1 quoteNumber riêng)
  title          String
  toCompany      String // legacy free-text; kept for backwards compat
  toContact      String?
  toEmail        String? // recipient email for the "Kính gửi" block
  toPhone        String? // recipient phone (To · Tel)
  toAddress      String? // recipient address (To · Add)
  customerId     Int? // new: link to CRM Customer (optional during migration)
  customer       Customer?   @relation(fields: [customerId], references: [id])
  companyId      Int
  company        Company     @relation(fields: [companyId], references: [id])
  fromContact    String
  fromPhone      String?
  fromTitle      String?
  fromAddress    String
  city           String
  quoteDate      DateTime
  executionDate  DateTime? // ngày thi công (lắp đặt) — CHỈ hiển thị trong app + trang Quản lý dự án, KHÔNG xuất Excel
  customerLogo   String?     @db.Text // base64 data URL of customer logo (inserted into templates that have a logo anchor)
  greeting       String      @default("Chân thành cảm ơn Quí khách hàng đã quan tâm đến dịch vụ của chúng tôi, chúng tôi xin gởi bảng báo giá theo yêu cầu như sau:")
  vatPercent     Decimal     @default(8) @db.Decimal(5, 2)
  status         QuoteStatus @default(draft)
  notes          String?
  showTotals     Boolean     @default(true) // hiện/ẩn bảng Tổng cộng–VAT–Thành tiền (tuỳ template/báo giá)
  currentVersion Int         @default(1)

  subtotal Decimal @default(0) @db.Decimal(18, 2)
  vat      Decimal @default(0) @db.Decimal(18, 2)
  discount Decimal @default(0) @db.Decimal(18, 2)
  total    Decimal @default(0) @db.Decimal(18, 2)

  createdById  Int
  createdBy    User  @relation("CreatedBy", fields: [createdById], references: [id])
  approvedById Int?
  approvedBy   User? @relation("ApprovedBy", fields: [approvedById], references: [id])

  sheets    QuoteSheet[]
  versions  QuoteVersion[]
  approvals Approval[]
  members   User[]         @relation("QuoteMembers") // nhân viên được thêm vào để xem/sửa

  sentAt      DateTime?
  convertedAt DateTime?

  // ===== Phần GIÁ HÀ NỘI (role account_hn) — luồng RIÊNG, tách khỏi `status` báo giá chính.
  // Quản lý GIAO account điền bảng nội bộ loại "hanoi"; account chỉ thấy/sửa phần đó rồi
  // GỬI DUYỆT; quản lý DUYỆT/TRẢ. =====
  hnAssigneeId  Int? // account_hn được giao (cũng được thêm vào members để thấy báo giá)
  hnStatus      String? // null=chưa giao · assigned · submitted · approved · rejected
  hnSubmittedAt DateTime? // account bấm "Gửi duyệt"
  hnReviewerId  Int? // quản lý duyệt/trả phần HN
  hnReviewedAt  DateTime?
  hnRejectNote  String? // lý do trả lại khi rejected

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Mỗi mã dự án chỉ có 1 bản cho mỗi version (v1/v2/v3…). Chặn race "Bản mới cùng mã"
  // tạo hai _v2 song song. projectCode null → Postgres coi NULL là khác nhau (quote không
  // có mã không bị ảnh hưởng). Version tính gồm cả bản xóa-mềm nên không tái dùng số.
  @@unique([projectCode, projectVersion])
  @@index([status, createdAt(sort: Desc)])
  @@index([companyId, status])
  @@index([customerId])
  @@index([createdById])
  @@index([approvedById])
  @@index([deletedAt])
}

model QuoteVersion {
  id          BigInt   @id @default(autoincrement())
  quoteId     Int
  quote       Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  versionNo   Int
  payload     Json // full snapshot of fields + sheets + items at this revision
  total       Decimal  @db.Decimal(18, 2)
  createdById Int?
  createdBy   User?    @relation("VersionAuthor", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())

  @@unique([quoteId, versionNo])
  @@index([quoteId, versionNo(sort: Desc)])
  @@index([createdById])
}

model QuoteSheet {
  id            Int           @id @default(autoincrement())
  quoteId       Int
  quote         Quote         @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  templateId    Int
  template      QuoteTemplate @relation(fields: [templateId], references: [id])
  order         Int
  name          String?
  groupSubtotal Boolean       @default(false) // hiện tổng tiền theo từng nhóm A/B/C
  items         QuoteItem[]
  // Bảng nội bộ (CHỈ quản lý — KHÔNG xuất Excel, KHÔNG cộng vào tổng báo giá). Mỗi phần tử:
  // { category: "hcm"|"hanoi"|"khach", name, items: [{kind,name,detail,unit,quantity,unitPrice,days,notes,formulas}] }.
  // Tổng theo từng loại đổ vào cột Chi Phí HCM / Báo Giá Hà Nội / Phí Khách Hàng ở trang Quản lý dự án.
  extraTables   Json?
  // Ký chứng từ theo từng sheet (chỉ quản lý — admin/người có canSign mới ký).
  signedAt      DateTime?
  signedById    Int?
  // FK to the signer. onDelete: SetNull — if the user is deleted we keep the sheet
  // and the snapshotted signedByName, just clear the link (audit-safe).
  signedBy      User?         @relation("SheetSigner", fields: [signedById], references: [id], onDelete: SetNull)
  signedByName  String?
  // Luồng hoá đơn ở trang Quản lý dự án (CHỈ admin nhập). Trạng thái suy ra: đã chốt →
  // "Hoá đơn"; có invoiceNo → "Thanh toán"; có CẢ invoiceNo + paidAt → "Done".
  invoiceNo     String?  // Số hoá đơn / mã HĐ
  paidAt        DateTime? // Ngày khách thanh toán
  // Theo dõi chứng từ ở Quản lý dự án (đèn đỏ = cần làm, trắng = đã xong). CHỈ admin nhập.
  poNumber      String?   // Số PO/HĐ — có giá trị thì "kích hoạt" 4 việc chứng từ bên dưới
  hnInvoiceNo   String?   // Số HĐ HN — đỏ khi báo giá Hà Nội đã DUYỆT mà chưa có số
  invoiceLink   String?   // Link Hoá Đơn (URL bản scan/PDF)
  docSentAt     DateTime? // Chứng từ gửi đi (ngày gửi)
  docReturnedAt DateTime? // Chứng từ trả về (ngày nhận lại)

  @@index([quoteId, order])
  @@index([signedById])
}

model QuoteItem {
  id           Int        @id @default(autoincrement())
  sheetId      Int
  sheet        QuoteSheet @relation(fields: [sheetId], references: [id], onDelete: Cascade)
  order        Int
  productId    Int? // optional link to catalog
  product      Product?   @relation(fields: [productId], references: [id], onDelete: SetNull)
  kind         String     @default("item") // "item" | "sub" | "info" | "section" (nhóm A/B/C)
  label        String? // chữ nhóm tự đặt cho kind=section (A/B/C…); rỗng = tự đánh theo thứ tự
  name         String // Hạng Mục (các dòng cùng name liên tiếp = 1 nhóm: gộp STT + ô Hạng Mục)
  detail       String?
  unit         String?
  quantity     Decimal    @default(0) @db.Decimal(18, 4)
  unitPrice    Decimal    @default(0) @db.Decimal(18, 4)
  days         Decimal?   @db.Decimal(10, 2)
  notes        String?
  internalNote String? // ghi chú NỘI BỘ — chỉ xem/quản lý, KHÔNG xuất Excel/PDF (không có trong itemsCfg.columns)
  formulas     Json? // raw Excel-style formulas per numeric field, e.g. {"unitPrice":"=2000+3000"} — editor metadata, not used in totals/export

  @@index([sheetId, order])
  @@index([productId])
}

// === Approval workflow ===
model Approval {
  id         Int              @id @default(autoincrement())
  quoteId    Int
  quote      Quote            @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  versionNo  Int
  level      Int
  approverId Int?
  approver   User?            @relation(fields: [approverId], references: [id])
  decision   ApprovalDecision @default(pending)
  comment    String?
  decidedAt  DateTime?
  createdAt  DateTime         @default(now())

  @@unique([quoteId, versionNo, level])
  @@index([approverId, decision])
}

// === Notification ===
model Notification {
  id         BigInt              @id @default(autoincrement())
  userId     Int
  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel    NotificationChannel @default(in_app)
  title      String
  body       String
  link       String?
  resource   String?
  resourceId String?
  readAt     DateTime?
  createdAt  DateTime            @default(now())

  @@index([userId, readAt, createdAt(sort: Desc)])
}

// === Settings (key-value per tenant - global for now) ===
model Setting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

// === Counters ===
model QuoteCounter {
  id     Int    @id @default(autoincrement())
  prefix String
  year   Int
  value  Int    @default(0)

  @@unique([prefix, year])
}

model CustomerCounter {
  id     Int    @id @default(autoincrement())
  prefix String
  year   Int
  value  Int    @default(0)

  @@unique([prefix, year])
}

// === Audit ===
model AuditEvent {
  id         BigInt   @id @default(autoincrement())
  actorId    Int?
  actor      User?    @relation(fields: [actorId], references: [id])
  action     String
  resource   String?
  resourceId String?
  before     Json?
  after      Json?
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([actorId, createdAt(sort: Desc)])
  @@index([resource, resourceId, createdAt(sort: Desc)])
  @@index([action, createdAt(sort: Desc)])
}

// === Webhook out (integrations) ===
model Webhook {
  id         Int               @id @default(autoincrement())
  url        String
  events     String[]          @default([]) // ["quote.approved", "quote.sent", ...]
  secret     String // HMAC signing secret
  active     Boolean           @default(true)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  deliveries WebhookDelivery[]

  @@index([active])
}

model WebhookDelivery {
  id             BigInt    @id @default(autoincrement())
  webhookId      Int
  webhook        Webhook   @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  event          String
  payload        Json
  responseStatus Int?
  responseBody   String?
  attempt        Int       @default(1)
  deliveredAt    DateTime?
  createdAt      DateTime  @default(now())

  @@index([webhookId, createdAt(sort: Desc)])
}


/// Session store table managed by connect-pg-simple (express-session).
/// Declared here only so `prisma db push` adopts it instead of dropping it.
model user_sessions {
  sid    String   @id(map: "session_pkey") @db.VarChar
  sess   Json     @db.Json
  expire DateTime @db.Timestamp(6)

  @@index([expire], map: "IDX_session_expire")
}

model LoginAttempt {
  id        BigInt   @id @default(autoincrement())
  username  String
  ip        String?
  userAgent String?
  success   Boolean
  reason    String?
  createdAt DateTime @default(now())

  @@index([username, createdAt(sort: Desc)])
  @@index([ip, createdAt(sort: Desc)])
}
