    "@prisma/client": "^7.8.0",
    "@sentry/node": "^10.55.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.77.6",
    "compression": "^1.8.1",
    "connect-pg-simple": "^9.0.1",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.21.1",
    "express-rate-limit": "^8.5.2",
    "express-session": "^1.18.1",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.2.0",
    "nanoid": "^5.1.11",
    "nodemailer": "^9.0.1",
    "pdf-fontkit": "^1.8.9",
    "pdfkit": "^0.18.0",
    "pg": "^8.13.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.8.0",
    "prom-client": "^15.1.3",
    "qrcode": "^1.5.4",
    "rate-limit-redis": "^5.0.0",
