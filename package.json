    "@types/node": "^22.10.0",
    "@types/nodemailer": "^8.0.1",
    "@types/pdfkit": "^0.17.6",
    "@types/qrcode": "^1.5.6",
    "@types/speakeasy": "^2.0.10",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "playwright": "^1.61.0",
    "supertest": "^7.2.2",
    "typescript": "^5.7.2",
