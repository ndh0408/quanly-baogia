{
  "name": "quanly-baogia",
  "version": "1.0.0",
  "description": "He thong quan ly bao gia Gia Nguyen",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "tsx watch src/server.js",
    "start": "tsx src/server.js",
    "worker": "tsx src/worker.js",
    "typecheck": "tsc --noEmit",
    "web:build": "npm --prefix web ci && npm --prefix web run build",
    "web:test": "npm --prefix web run test",
    "e2e:hr": "node e2e-hr.mjs",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "node prisma/seed.js",
    "db:studio": "prisma studio",
    "setup": "prisma migrate deploy && node prisma/seed.js",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "engines": {
    "node": ">=22"
  },
  "private": true,
  "license": "UNLICENSED",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1055.0",
    "@aws-sdk/s3-request-presigner": "^3.1055.0",
