{
  // Backend TypeScript. Chạy bằng tsx (esbuild strip types — KHÔNG cần build). tsc chỉ để
  // `npm run typecheck` (noEmit). allowJs=true → code .js cũ chạy chung, migrate .ts DẦN DẦN.
  // strict bật DẦN sau (giờ false để chuyển mượt, không gãy luồng đang chạy).
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2023"],
    "types": ["node"],
    "allowJs": true,
    "checkJs": false,
    "strict": false,
    "noImplicitAny": false,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*.ts", "src/**/*.js"],
  "exclude": ["node_modules", "web", "public", "tests", "prisma/seed*.js"]
}
