{
  // Backend TypeScript. Chạy bằng tsx (esbuild strip types — KHÔNG cần build). tsc chỉ để
  // `npm run typecheck` (noEmit). allowJs=true → vài file .js cũ (exportWorker) chạy chung.
  // strict=true (siết null/undefined/unknown — BẮT BUG an toàn, đã vá toàn bộ). noImplicitAny=false
  // CỐ Ý: cho phép param req/res… ngầm any (boilerplate Express), siết dần ở pass riêng sau.
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2023"],
    "types": ["node"],
    "allowJs": true,
    "checkJs": false,
    "strict": true,
    "noImplicitAny": false,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*.ts", "src/**/*.js"],
  "exclude": ["node_modules", "web", "public", "tests", "prisma/seed*.js"]
}
