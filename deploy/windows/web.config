<?xml version="1.0" encoding="UTF-8"?>
<!--
  IIS reverse proxy cho app QuanLY (Node.js chạy ở 127.0.0.1:3000).

  Yêu cầu cài trên server (1 lần):
    - URL Rewrite 2.1
    - Application Request Routing (ARR) 3.0
    - Đã bật "Enable proxy" trong ARR  (script 4-setup-iis-proxy.ps1 tự làm)
    - Đã cho phép server variable HTTP_X_FORWARDED_PROTO / HTTP_X_FORWARDED_HOST
      (script 4-setup-iis-proxy.ps1 tự làm)

  File này được COPY vào thư mục gốc (physical path) của site gianguyen.cloud,
  thay cho web.config của app C# cũ (script 4 sẽ backup file cũ trước).
-->
<configuration>
  <system.webServer>

    <rewrite>
      <rules>
        <rule name="QuanLY-ReverseProxy" stopProcessing="true">
          <match url="(.*)" />
          <serverVariables>
            <!-- BẮT BUỘC: Express dùng secure cookie ở production.
                 Thiếu header này thì đăng nhập xong KHÔNG giữ được session. -->
            <set name="HTTP_X_FORWARDED_PROTO" value="https" />
            <set name="HTTP_X_FORWARDED_HOST" value="{HTTP_HOST}" />
          </serverVariables>
          <action type="Rewrite" url="http://127.0.0.1:3000/{R:1}" />
        </rule>
      </rules>
    </rewrite>

    <!-- Cho upload tới 50MB (logo công ty, file đính kèm) -->
    <security>
      <requestFiltering>
        <requestLimits maxAllowedContentLength="52428800" />
      </requestFiltering>
    </security>

    <!-- Để Node tự trả trang lỗi/của nó, IIS không chèn trang lỗi riêng -->
    <httpErrors existingResponse="PassThrough" />

  </system.webServer>
</configuration>
