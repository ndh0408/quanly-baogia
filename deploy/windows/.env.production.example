################ MÔI TRƯỜNG PRODUCTION (Windows Server) ################
# Copy file này thành ".env" trong thư mục gốc app rồi điền giá trị thật.
# Script 2-deploy-app.ps1 sẽ TỰ TẠO .env và sinh sẵn 2 secret nếu .env chưa tồn tại.

NODE_ENV=production
PORT=3000
LOG_LEVEL=info

################ DATABASE (PostgreSQL đã cài sẵn trên server) ################
# Đổi DB_PASSWORD cho khớp role 'quanly' tạo ở bước 1-setup-database.ps1
DATABASE_URL="postgresql://quanly:DB_PASSWORD@localhost:5432/quanly?schema=public"

################ SESSION / JWT — BẮT BUỘC ở production ################
# Mỗi cái ≥ 32 ký tự, JWT_SECRET PHẢI KHÁC SESSION_SECRET.
# Sinh nhanh: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
SESSION_SECRET=""
JWT_SECRET=""

################ MẠNG / PROXY ################
# Đứng sau IIS reverse proxy → BẮT BUỘC để req.ip + secure cookie hoạt động đúng.
TRUST_PROXY=1
# BẮT BUỘC ở production: origin công khai người dùng truy cập (dùng cho link email
# reset/invite VÀ cho CSRF allowlist). Phải khớp đúng URL trình duyệt mở.
APP_BASE_URL=https://gianguyen.cloud
CORS_ORIGINS=https://gianguyen.cloud

################ REDIS (Memurai trên Windows) ################
REDIS_URL=redis://127.0.0.1:6379

################ S3 — KHÔNG BẮT BUỘC ################
# Để trống. Export Excel/PDF không cần S3. Chỉ cần nếu muốn lưu file đính kèm/logo lên object storage.
# S3_ENDPOINT=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET=quanly

################ TÀI KHOẢN ADMIN (chỉ dùng cho lần seed đầu) ################
ADMIN_USERNAME=admin
# Để trống ADMIN_PASSWORD → seed tự sinh mật khẩu mạnh, ghi ra .admin-credentials.local
ADMIN_PASSWORD=
ADMIN_DISPLAY_NAME="Quản trị viên"

################ TÙY CHỌN ################
# METRICS_TOKEN=  # bearer-gate cho /metrics
# SENTRY_DSN=
# TELEGRAM_BOT_TOKEN=
