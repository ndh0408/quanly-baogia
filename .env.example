################ ENV ################
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

################ DATABASE ################
DATABASE_URL="postgresql://quanly:CHANGE_ME@localhost:5432/quanly?schema=public"

################ SESSION ################
# REQUIRED ≥ 32 chars in production. Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
SESSION_SECRET=""

################ AUTH HARDENING ################
BCRYPT_COST=12
PASSWORD_MIN_LENGTH=8
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
RATE_LIMIT_LOGIN_PER_15M=10
RATE_LIMIT_API_PER_MIN=120

################ PAGINATION ################
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

################ NETWORK ################
# Set when behind Nginx / Cloudflare so req.ip is the real client IP.
# 1 = trust first hop, true = trust all. Leave empty for direct connect.
TRUST_PROXY=

################ SEED ################
# Leave ADMIN_PASSWORD empty to have seed generate a strong one and write to .admin-credentials.local
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
ADMIN_DISPLAY_NAME="Quản trị viên"
